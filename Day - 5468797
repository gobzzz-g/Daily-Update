class Solution:
    def sequentialDigits(self, low: int, high: int) -> list[int]:
        seqNumbersList = []
        listOfDigits = [1, 2, 3, 4, 5, 6, 7, 8, 9]
        listOfNumbers = [1, 2, 3, 4, 5, 6, 7, 8, 9]

        j = 0
        current_length = 1

        while current_length < len(listOfDigits) - 1:
            if j + current_length == len(listOfDigits):
                j = 0
                current_length += 1

            seqNumber = (
                listOfNumbers[j] * 10
                + listOfDigits[j + current_length]
            )
            seqNumbersList.append(seqNumber)
            listOfNumbers[j] = seqNumber
            j += 1

        return [
            number
            for number in seqNumbersList
            if low <= number <= high
        ]
